rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isParticipant(chatData) {
      return request.auth.uid in chatData.participants;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isBlockable(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.blockable == true;
    }

    // ── Users collection: users/{uid} ────────────────────────────────────────
    match /users/{uid} {
      // Anyone authenticated can read public profiles
      // (profile visibility is enforced at app level for privacy)
      allow read: if isAuth();

      // Only the user can create/update their own document
      allow create: if isAuth() && isOwner(uid)
        && request.resource.data.keys().hasAll(['uid','username','displayName','email','blockable','blockedUsers','settings'])
        && request.resource.data.uid == uid
        // Protect blockable field — cannot set yourself as non-blockable on create
        && request.resource.data.blockable == true;

      allow update: if isAuth() && isOwner(uid)
        // Cannot change blockable field (only admin can set blockable:false)
        && request.resource.data.blockable == resource.data.blockable
        // Cannot change uid
        && request.resource.data.uid == resource.data.uid;

      allow delete: if false; // No deletions via client
    }

    // ── PeerJS ID lookup: peerIds/{uid} ──────────────────────────────────────
    match /peerIds/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    // ── Chats: chats/{chatId} ────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth() && isParticipant(resource.data);

      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow update: if isAuth() && isParticipant(resource.data);

      allow delete: if false;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuth()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data);

        allow create: if isAuth()
          && isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.deleted == false;

        // Only sender can soft-delete (set deleted:true)
        allow update: if isAuth()
          && resource.data.senderId == request.auth.uid
          && request.resource.data.deleted == true
          && request.resource.data.keys().hasOnly(['deleted', 'content']);

        allow delete: if false;
      }
    }

    // ── Call records: calls/{callId} ─────────────────────────────────────────
    match /calls/{callId} {
      allow read: if isAuth()
        && (resource.data.callerId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      allow create: if isAuth()
        && (request.resource.data.callerId == request.auth.uid
            || request.resource.data.receiverId == request.auth.uid);

      allow update: if isAuth()
        && (resource.data.callerId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      allow delete: if false;
    }
    // ─────────────────────────────────────────────
    // Meetings Collection
    // ─────────────────────────────────────────────
    match /meetings/{meetingId} {

      function isAuth() {
        return request.auth != null;
      }

      function isHost() {
        return isAuth() && resource.data.hostUid == request.auth.uid;
      }

      function isParticipant() {
        return isAuth() &&
          request.auth.uid in resource.data.participants;
      }

      function isCoHost() {
        return isParticipant() &&
          resource.data.participants[request.auth.uid].role == 'co-host';
      }

      function canManage() {
        return isHost() || isCoHost();
      }

      // ─── READ ─────────────────────────────
      allow get: if isAuth();
      allow list: if isParticipant() || isHost();

      // ─── CREATE ───────────────────────────
      allow create: if isAuth()
        && request.resource.data.hostUid == request.auth.uid;

      // ─── UPDATE ───────────────────────────
      allow update: if isAuth() && (
        // Host can do anything
        isHost()

        // Co-host can manage participants/settings (limited)
        || (
          isCoHost()
          && request.resource.data.hostUid == resource.data.hostUid
        )

        // Participant can update ONLY their own state
        // OR a new participant can join by adding themselves
        || (
          request.resource.data.hostUid == resource.data.hostUid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
          && request.resource.data.participants.diff(resource.data.participants).affectedKeys().hasOnly([request.auth.uid])
          && (
            // If already a participant, ensure role hasn't changed
            (isParticipant() && request.resource.data.participants[request.auth.uid].role == resource.data.participants[request.auth.uid].role)
            // If joining, must join as attendee
            || (!(request.auth.uid in resource.data.participants) && request.resource.data.participants[request.auth.uid].role == 'attendee')
          )
        )
      );

      // ─── DELETE ───────────────────────────
      allow delete: if isHost();

      // ─────────────────────────────────────
      // Chat Subcollection
      // ─────────────────────────────────────
      match /chat/{messageId} {

        function isParticipant() {
          return request.auth != null &&
            request.auth.uid in get(/databases/$(database)/documents/meetings/$(meetingId)).data.participants;
        }

        allow read: if isParticipant();

        allow create: if isParticipant()
          && request.resource.data.senderUid == request.auth.uid;

        allow delete: if false; // no deletes for now
        allow update: if false;
      }
    }
  }
}
